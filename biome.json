{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/src/**/*",
			"**/.vscode/**/*",
			"**/index.html",
			"**/vite.config.ts",
			"!**/src/styles.css",
			"!**/src/app/paraglide",
			"!**/src/paraglide",
			"!!**/routeTree.gen.ts"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"nursery": {
				"useSortedClasses": {
					"level": "error",
					"fix": "safe",
					"options": {
						"attributes": ["classList"],
						"functions": ["clsx", "cva", "tw", "tw.*"]
					}
				}
			},
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		},
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.ts"],
			"linter": {
				"rules": {
					"correctness": {
						"useHookAtTopLevel": "off"
					}
				}
			}
		},
		{
			"includes": [
				"**/src/app/components/ui/button-group.tsx",
				"**/src/app/components/ui/input-group.tsx",
				"**/src/app/components/ui/item.tsx"
			],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off",
						"useKeyWithClickEvents": "off"
					}
				}
			}
		}
	]
}
